# ─── Supabase PostgreSQL ─────────────────────────────────────────────────────
# Copie a connection string EXATA do dashboard:
#   Supabase → Connect → ORMs → Prisma
#
# ⚠️ ATENÇÃO — dois detalhes que quebram o app se errados:
#
# 1) O host do pooler pode ser `aws-0-<região>` OU `aws-1-<região>`. NÃO chute:
#    cada projeto vive num pooler específico. Se errar, o Postgres responde
#    "FATAL: Tenant or user not found" mesmo com senha correta.
#
# 2) DATABASE_URL (porta 6543, transaction mode) PRECISA de `?pgbouncer=true`.
#    Sem isso o Prisma falha intermitente com:
#    'prepared statement "s0" already exists' (erro 42P05).
#    DIRECT_URL (porta 5432, session mode) NÃO leva esse parâmetro.

DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Gere o secret com: openssl rand -base64 32
# Trocar o secret invalida todas as sessões existentes (cookies antigos passam
# a dar JWT_SESSION_ERROR até o usuário logar de novo).
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"
# Em produção precisa ser a URL https real — é ela que define o nome do cookie
# de sessão (__Secure-*) e o middleware depende disso pra validar o login.
NEXTAUTH_URL="http://localhost:3001"

# ─── Supabase Storage (upload de imagens) ────────────────────────────────────
# Supabase → Settings → API Keys
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."
# ⚠️ NUNCA exponha a service role key no client — uso server-side apenas.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ─── Geral ───────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE="America/Sao_Paulo"
